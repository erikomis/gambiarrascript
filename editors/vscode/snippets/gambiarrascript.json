{
  "Gambiarra (funcao)": {
    "prefix": "gambiarra",
    "body": ["gambiarra ${1:nome}(${2:args})", "\t${0}", "acabou_finalmente"],
    "description": "Declara uma funcao"
  },
  "Se colar (if)": {
    "prefix": "se_colar",
    "body": ["se_colar ${1:condicao}", "\t${0}", "acabou_finalmente"],
    "description": "Condicional"
  },
  "Pra cada (numerico)": {
    "prefix": "pra_cada",
    "body": ["pra_cada ${1:i} de ${2:1} ate ${3:10}", "\t${0}", "acabou_finalmente"],
    "description": "Laco numerico"
  },
  "Enquanto (while)": {
    "prefix": "enquanto",
    "body": ["enquanto ${1:condicao}", "\t${0}", "acabou_finalmente"],
    "description": "Laco while"
  },
  "Arruma (try/catch)": {
    "prefix": "arruma",
    "body": ["arruma", "\t${1}", "quebrou ${2:erro}", "\t${0}", "acabou_finalmente"],
    "description": "Tratamento de erro"
  },
  "Pra cada (colecao)": {
    "prefix": "pra_cada_em",
    "body": ["pra_cada ${1:item} em ${2:colecao}", "\t${0}", "acabou_finalmente"],
    "description": "Laco sobre lista ou dicionario"
  },
  "Busca (HTTP)": {
    "prefix": "busca",
    "body": ["bota ${1:resp} = busca(\"${2:https://}\")"],
    "description": "Requisicao HTTP (cliente)"
  },
  "Rota (servidor)": {
    "prefix": "rota",
    "body": [
      "gambiarra ${1:handler}(pedido)",
      "\tfunciona ${2:\"salve\"}",
      "acabou_finalmente",
      "rota(\"${3:GET}\", \"${4:/}\", ${1:handler})"
    ],
    "description": "Registra uma rota HTTP"
  },
  "Escuta (servidor)": {
    "prefix": "escuta",
    "body": ["escuta(${1:8080})"],
    "description": "Sobe o servidor HTTP na porta"
  }
}
