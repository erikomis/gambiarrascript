{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GambiarraScript",
  "scopeName": "source.gambiarrascript",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#funcdecl" },
    { "include": "#builtins" },
    { "include": "#keywords" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.gambiarrascript",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "match": "#.*$",
          "name": "comment.line.number-sign.gambiarrascript"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.gambiarrascript",
      "begin": "\"",
      "end": "\""
    },
    "numbers": {
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
      "name": "constant.numeric.gambiarrascript"
    },
    "constants": {
      "match": "\\b(deu_bom|deu_ruim|nada)\\b",
      "name": "constant.language.gambiarrascript"
    },
    "funcdecl": {
      "match": "\\b(gambiarra)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.gambiarrascript" },
        "2": { "name": "entity.name.function.gambiarrascript" }
      }
    },
    "builtins": {
      "match": "\\b(tamanho|chaves|tem|texto|numero|busca|rota|escuta|de_json|pra_json|separa|junta|maiusculo|minusculo|substitui|fatia|contem|comeca_com|termina_com|tira_espaco|adiciona|remove|ordena|inverte|mapeia|filtra|raiz|aleatorio|arredonda|teto|chao|abs|min|max|le_arquivo|escreve_arquivo|pergunta|argumentos)\\b",
      "name": "support.function.builtin.gambiarrascript"
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(se_colar|se_nao_colar|enquanto|pra_cada|de|ate|em|vaza|continua|arruma|quebrou|acabou_finalmente|funciona|importa)\\b",
          "name": "keyword.control.gambiarrascript"
        },
        {
          "match": "\\b(bota|gambiarra|mostra)\\b",
          "name": "keyword.declaration.gambiarrascript"
        },
        {
          "match": "\\b(e|ou|nao)\\b",
          "name": "keyword.operator.word.gambiarrascript"
        }
      ]
    }
  }
}
